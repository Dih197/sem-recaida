{
  "name": "sem-recaida",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @sem-recaida/web exec prisma migrate dev",
    "db:push": "pnpm --filter @sem-recaida/web exec prisma db push",
    "db:studio": "pnpm --filter @sem-recaida/web exec prisma studio",
    "db:seed": "pnpm --filter @sem-recaida/web exec prisma db seed"
  },
  "devDependencies": {
    "@prisma/client": "5.22.0",
    "prisma": "5.22.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  }
}
